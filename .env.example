# ==========================================
# Solar Tecnologia — Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env.local e preencha com valores reais
# NUNCA commite o arquivo .env.local no git

# ----- Banco de Dados -----
# Use um usuário dedicado (não postgres/superuser)
DATABASE_URL="postgresql://<usuario>:<senha_forte>@localhost:5432/<banco>?schema=public"
POSTGRES_USER=<usuario_db>
POSTGRES_PASSWORD=<senha_forte_minimo_16_chars>
POSTGRES_DB=<nome_banco>

# ----- JWT / Autenticação -----
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<chave_aleatoria_minimo_64_chars>

# ----- App -----
NEXTAUTH_URL="http://localhost:3101"
NODE_ENV=development

# ----- WhatsApp -----
# Número no formato internacional sem + ou espaços (ex: 5585999999999)
WHATSAPP_NUMBER=<numero_whatsapp_internacional>

# ----- Email (Gmail SMTP) -----
# Use uma "App Password" do Google: https://myaccount.google.com/apppasswords
# A conta Gmail precisa ter verificação em duas etapas ativada
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="<seu_email@gmail.com>"
SMTP_PASS="<app_password_16_chars_sem_espacos>"
SMTP_FROM="<seu_email@gmail.com>"
# E-mail que receberá os leads do formulário "Agendar uma visita"
SMTP_TO="<email_destino@empresa.com>"
